{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist-scripts",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/scripts/**/*.ts",
    "src/lib/portal-data.ts"
  ],
  "exclude": ["node_modules"]
}
